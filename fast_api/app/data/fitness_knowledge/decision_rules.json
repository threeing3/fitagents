  {
    "rule_id": "rule_plateau_strength_3week_stall_001",
    "rule_type": "progression",
    "intent": "progression_decision",
    "description": "主要动作连续3周以上没有进步（重量或次数停滞），疲劳和睡眠正常时，应引入周期化变化：更换次数区间、增加辅助动作或安排一次减载周。",
    "condition_json": {
      "all": [
        {"path": "exercise_history[*].progression_status", "op": "contains", "value": "stalled"},
        {"path": "exercise_history[*].stall_weeks", "op": ">=", "value": 3},
        {"path": "recent_recovery[0].fatigue_score", "op": "<=", "value": 7},
        {"path": "recent_recovery[0].sleep_hours", "op": ">=", "value": 6}
      ]
    },
    "action_json": {
      "decision": "apply_periodization_change",
      "options": ["change_rep_range", "add_variation", "schedule_deload", "increase_frequency"],
      "reason": "连续3周以上停滞且恢复状态正常时，不是疲劳问题而是适应问题。需要新的训练刺激打破平台期——可以尝试改变次数区间（如5x5换3x8-10）、加入变式动作或安排减载周后再冲。"
    },
    "priority": 70,
    "safety_level": "general",
    "enabled": true,
    "version": "v1"
  },
  {
    "rule_id": "rule_plateau_fat_loss_2week_stall_001",
    "rule_type": "nutrition_strategy",
    "intent": "nutrition_advice",
    "description": "减脂期连续2周体重无明显变化且饮食依从性良好时，优先检查隐性热量摄入和NEAT下降，而非直接大幅降热量。",
    "condition_json": {
      "all": [
        {"path": "core_profile.goal", "op": "contains", "value": "fat_loss"},
        {"path": "recent_checkins[*].weight_change_kg", "op": ">=", "value": -0.3},
        {"path": "recent_checkins[*].weight_change_kg", "op": "<=", "value": 0.3},
        {"path": "recent_checkins[*].nutrition_adherence", "op": ">=", "value": 0.7}
      ]
    },
    "action_json": {
      "decision": "audit_before_cutting_calories",
      "steps": ["check_liquid_calories", "check_cooking_oils_sauces", "increase_daily_steps_by_2000", "ensure_sleep_7h"],
      "reason": "体重停滞2周且饮食依从性好时，直接降热量可能适得其反。优先排查隐性热量（饮料、酱料、烹饪油）、增加日常活动量（NEAT），多数情况下比再降200卡更可持续。"
    },
    "priority": 75,
    "safety_level": "general",
    "enabled": true,
    "version": "v1"
  },
  {
