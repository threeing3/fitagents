# AI Fitness Coach Agent local configuration
# Copy to .env and fill DEEPSEEK_API_KEY when you want live DeepSeek calls.

PROJECT_NAME=ai-fitness-coach-agent
VERSION=0.1.0
ENVIRONMENT=development

# PostgreSQL + pgvector
DB_USER=fitness
DB_PASSWORD=fitness
DB_NAME=ai_fitness_agent
DATABASE_URL=postgresql+psycopg://fitness:fitness@localhost:4553/ai_fitness_agent
VECTOR_DIMENSION=1024
USE_PGVECTOR=true

# Production scaling knobs
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_CHAT=15/minute
RATE_LIMIT_PLAN=10/minute
RATE_LIMIT_NUTRITION=8/minute
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
BACKGROUND_TASK_MAX_ATTEMPTS=3

# Model provider abstraction
LLM_PROVIDER=deepseek
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_API_KEY=
EMBEDDING_PROVIDER=qwen

# Future provider switches
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Observability
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=ai-fitness-coach
LANGSMITH_API_KEY=

# Local frontend
CORS_ORIGINS=http://localhost:5173
