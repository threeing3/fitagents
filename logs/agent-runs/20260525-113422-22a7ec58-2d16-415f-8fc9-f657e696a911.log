in_001", "topic": "fat_loss_protein", "content": "减脂期提高蛋白质摄入通常有三个作用：帮助保留瘦体重，提高饱腹感，并让力量训练后的恢复更稳定。普通健身用户可以用体重每公斤约1.6-2.2g蛋白质作为起点，再根据消化、预算和训练量调整。", "tags": ["fat_loss", "protein", "nutrition"], "source": "internal_seed_v1", "safety_level": "general"}, {"knowledge_id": "exp_progressive_overload_001", "topic": "progressive_overload", "content": "渐进超负荷不是每次都强行加重量，而是在动作质量稳定、目标次数完成、RPE可控、恢复良好的情况下，逐步增加重量、次数、组数或动作难度。疲劳高或睡眠差时，维持重量甚至降量通常更合理。", "tags": ["training", "progression", "rpe"], "source": "internal_seed_v1", "safety_level": "general"}], "decision_rules": [], "plan_templates": [{"template_id": "tpl_training_fat_loss_intermediate_gym_5d_001", "template_type": "training", "goal": "fat_loss", "level": "intermediate", "days_per_week": 5, "equipment": ["gym", "barbell", "dumbbell", "machines"], "template_json": {"name": "5天健身房减脂力量模板", "split": ["上肢推", "下肢", "上肢拉", "休息或低强度有氧", "全身力量", "弱项与有氧", "休息"], "cardio": "每周2-3次20-35分钟低到中等强度有氧", "intensity": "多数动作RPE 7-8，保留1-3次余力"}, "constraints": {"avoid": ["max_effort_when_fatigued"], "requires": ["gym"]}, "version": "v1", "match_score": 10}, {"template_id": "tpl_training_beginner_gym_3d_001", "template_type": "training", "goal": "general_fitness", "level": "beginner", "days_per_week": 3, "equipment": ["gym", "machines", "dumbbell"], "template_json": {"name": "3天新手全身训练模板", "split": ["全身A", "休息", "全身B", "休息", "全身A", "休息", "休息"], "cardio": "训练后10-20分钟轻中等强度有氧", "intensity": "先学习动作，RPE 6-7"}, "constraints": {"avoid": ["max_effort"]}, "version": "v1", "match_score": 2}], "coaching_cases": [{"case_id": "case_takeout_nutrition_001", "case_type": "nutrition", "profile_summary": "用户减脂但平时不自己做饭。", "situation": "用户问今天吃什么或者外卖怎么选。", "coach_response_pattern": "给出可直接点的外食组合，优先说明蛋白质、主食、蔬菜和酱料控制，不要求用户自炊。", "tags": ["takeout", "fat_loss", "nutrition"], "source": "internal_seed_v1"}, {"case_id": "case_high_fatigue_adjustment_001", "case_type": "adjustment", "profile_summary": "减脂用户反馈睡眠差、疲劳高。", "situation": "用户今天疲劳8-9分，睡眠少于6小时，还问能不能继续冲重量。", "coach_response_pa